<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<style>
.about-page {
  padding-top: 0;
}

/* ── Main Image ── */
.about-hero-image {
  max-width: 580px;
  margin: 40px auto 0;
  padding: 0 56px;
}

.about-hero-image__frame {
  border-radius: var(--radius-lg, 18px);
  overflow: hidden;
  box-shadow: 0 24px 48px rgba(35, 27, 23, 0.10);
  border: 1px solid var(--line, #e8e3de);
  padding: 36px;
  background: var(--white, #fff);
}

.about-hero-image__frame img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
  border-radius: 12px;
}

/* ── Brand Heading & Tagline ── */
.about-brand {
  text-align: center;
  max-width: 640px;
  margin: clamp(36px, 6vw, 56px) auto clamp(40px, 7vw, 64px);
  padding: 0 20px;
}

.about-brand__eyebrow {
  display: inline-block;
  font-family: var(--font-body, sans-serif);
  text-transform: uppercase;
  letter-spacing: 0.22em;
  font-size: 0.76rem;
  font-weight: 600;
  color: var(--primary, #2f4f3e);
  margin-bottom: 14px;
}

.about-brand__heading {
  font-family: var(--font-display, serif);
  font-size: clamp(1.9rem, 4vw, 2.6rem);
  color: var(--text, #231b17);
  margin: 0 0 18px;
  font-weight: 400;
  line-height: 1.15;
}

.about-brand__tagline {
  font-family: var(--font-body, sans-serif);
  font-size: clamp(0.95rem, 1.8vw, 1.05rem);
  color: var(--text-muted, #7a7067);
  line-height: 1.8;
  margin: 0;
}

/* ── Policy Sections (Plain Text) ── */
.about-policies {
  max-width: 760px;
  margin: 0 auto clamp(60px, 8vw, 88px);
  padding: 0 20px;
}

.about-policy-block {
  border-top: 1.5px solid var(--line, #e8e3de);
  padding: 28px 0;
}

.about-policy-block:last-child {
  border-bottom: 1.5px solid var(--line, #e8e3de);
}

.about-policy-block__header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.about-policy-block__icon {
  color: var(--primary, #2f4f3e);
  font-size: 1.15rem;
  flex-shrink: 0;
  width: 24px;
  text-align: center;
}

.about-policy-block__title {
  font-family: var(--font-display, serif);
  font-size: 1.15rem;
  font-weight: 400;
  color: var(--text, #231b17);
  margin: 0;
}

.about-policy-block__list {
  list-style: none;
  padding: 0;
  margin: 0 0 0 36px;
}

.about-policy-block__list li {
  font-family: var(--font-body, sans-serif);
  font-size: 0.93rem;
  color: var(--text-muted, #7a7067);
  line-height: 1.75;
  padding: 5px 0;
  padding-left: 18px;
  position: relative;
}

.about-policy-block__list li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 14px;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--primary, #2f4f3e);
  opacity: 0.4;
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .about-hero-image {
    max-width: 100%;
    padding: 0 32px;
  }

  .about-hero-image__frame {
    padding: 24px;
  }

  .about-brand {
    padding: 0 16px;
  }

  .about-policies {
    padding: 0 16px;
  }

  .about-policy-block__list {
    margin-left: 36px;
  }
}

@media (max-width: 480px) {
  .about-hero-image {
    padding: 0 20px;
  }

  .about-hero-image__frame {
    padding: 18px;
  }

  .about-policy-block__list li {
    font-size: 0.88rem;
  }
}
</style>

<main class="about-page" id="main-content">
  <!-- About Hero -->
  <section class="shop-hero">
    <div class="container shop-hero__content">
      <nav class="shop-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>About</span>
      </nav>
      <h1 class="shop-hero__title">About Zayrah Couture</h1>
    </div>
  </section>

  <!-- Main Image -->
  <section class="about-hero-image">
    <div class="about-hero-image__frame">
      <img
        src="<%= (storeSettings.heroImagePrimary && storeSettings.heroImagePrimary.url) ? storeSettings.heroImagePrimary.url : 'https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=500&h=700&fit=crop' %>"
        alt="Zayrah Couture"
        loading="eager"
        width="680"
        height="900"
      />
    </div>
  </section>

  <!-- Brand Heading & Tagline -->
  <section class="about-brand">
    <span class="about-brand__eyebrow"><%= storeSettings.heroEyebrow || 'Our Story' %></span>
    <h2 class="about-brand__heading"><%= storeSettings.heroHeading || 'From Zayrah, With Love' %></h2>
    <p class="about-brand__tagline">
      <%= storeSettings.tagline || 'Elegant modest fashion for the modern woman' %>
    </p>
  </section>

  <!-- Policy Sections (Plain Text) -->
  <section class="about-policies" aria-label="Store Policies">
    <!-- Additional Information -->
    <div class="about-policy-block">
      <div class="about-policy-block__header">
        <i class="fa-solid fa-circle-info about-policy-block__icon"></i>
        <h3 class="about-policy-block__title">Additional Information</h3>
      </div>
      <ul class="about-policy-block__list">
        <% const additionalLines = (storeSettings.additionalInfo || '').split('\n').filter(l => l.trim()); %>
        <% additionalLines.forEach(function(line) { %>
          <li><%= line.replace(/^[•\-]\s*/, '') %></li>
        <% }); %>
      </ul>
    </div>

    <!-- Shipping Policy -->
    <div class="about-policy-block">
      <div class="about-policy-block__header">
        <i class="fa-solid fa-truck-fast about-policy-block__icon"></i>
        <h3 class="about-policy-block__title">Shipping Policy</h3>
      </div>
      <ul class="about-policy-block__list">
        <% const shippingLines = (storeSettings.shippingPolicy || '').split('\n').filter(l => l.trim()); %>
        <% shippingLines.forEach(function(line) { %>
          <li><%= line.replace(/^[•\-]\s*/, '') %></li>
        <% }); %>
      </ul>
    </div>

    <!-- Return & Exchange Policy -->
    <div class="about-policy-block">
      <div class="about-policy-block__header">
        <i class="fa-solid fa-rotate-left about-policy-block__icon"></i>
        <h3 class="about-policy-block__title">Return & Exchange Policy</h3>
      </div>
      <ul class="about-policy-block__list">
        <% const returnLines = (storeSettings.returnPolicy || '').split('\n').filter(l => l.trim()); %>
        <% returnLines.forEach(function(line) { %>
          <li><%= line.replace(/^[•\-]\s*/, '') %></li>
        <% }); %>
      </ul>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>

<script type="application/json" id="searchData"><%- JSON.stringify(searchableProducts) %></script>
<script type="application/json" id="categorySearchData"><%- JSON.stringify(featuredCategories.map(function(c) { return { title: c.title, slug: c.slug }; })) %></script>

<%- include('../partials/scripts') %>
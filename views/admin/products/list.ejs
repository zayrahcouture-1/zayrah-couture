<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zayrah | Products</title>
  <link rel="stylesheet" href="/css/admin/products/list.css" />
</head>
<body>

  <!-- ── Flash Toasts ── -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="toast toast--success" id="toast"><%= success %></div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="toast toast--error" id="toast"><%= error %></div>
  <% } %>

  <div class="dashboard">
    <!-- ── Sidebar ── -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__brand">
        <div class="brand-mark">Z</div>
        <div>
          <h2><span class="brand-name">Zayrah</span> Dashboard</h2>
          <p>Admin panel</p>
        </div>
      </div>

      <nav class="sidebar__nav">
        <a href="/admin/dashboard" class="nav-link">Overview</a>
        <a href="/admin/products" class="nav-link active">Products</a>
        <a href="/admin/categories" class="nav-link">Categories</a>
        <a href="#" class="nav-link">Settings</a>
      </nav>
    </aside>

    <!-- ── Mobile overlay ── -->
    <div class="overlay" id="overlay"></div>

    <!-- ── Main content ── -->
    <main class="main">
      <header class="topbar">
        <button class="menu-btn" id="menuBtn" aria-label="Open menu">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <div class="topbar__title">
          <h1>Products</h1>
          <p>Manage your product collection</p>
        </div>

        <div class="profile">
          <div class="avatar">AR</div>
          <div>
            <strong>Admin Rizan</strong>
            <span>Super Admin</span>
          </div>
        </div>
      </header>

      <!-- ── Toolbar ── -->
      <section class="toolbar">
        <div class="search-box">
          <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="searchInput" class="search-input" placeholder="Search products…" autocomplete="off" />
        </div>
        <a href="/admin/products/add" class="add-btn">+ Add Product</a>
      </section>

      <% if (products && products.length > 0) { %>
        <!-- ── Products Grid ── -->
        <section class="products-grid" id="productsGrid">
          <% products.forEach(function(product, index) { %>
            <article class="product-card" data-name="<%= product.name.toLowerCase() %>" style="animation-delay: <%= index * 0.05 %>s">
              <!-- Thumbnail -->
              <div class="product-thumb">
                <% if (product.images && product.images.length > 0) { %>
                  <img src="<%= product.images[0].url %>" alt="<%= product.name %>" />
                <% } else { %>
                  <div class="thumb-placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                  </div>
                <% } %>
                <div class="badge-container">
                  <% if (product.isFeatured) { %>
                    <span class="badge badge--featured">★ Featured</span>
                  <% } %>
                  <span class="badge badge--category"><%= product.category ? product.category.name : 'Uncategorized' %></span>
                </div>
              </div>

              <!-- Details -->
              <div class="product-body">
                <h3 class="product-name"><%= product.name %></h3>
                <span class="product-slug">/<%= product.slug %></span>

                <!-- Pricing -->
                <div class="product-pricing">
                  <% if (product.discountPrice && product.discountPrice > 0) { %>
                    <span class="price price--discounted">₹<%= product.discountPrice.toLocaleString('en-IN') %></span>
                    <span class="price price--original">₹<%= product.price.toLocaleString('en-IN') %></span>
                  <% } else { %>
                    <span class="price">₹<%= product.price.toLocaleString('en-IN') %></span>
                  <% } %>
                </div>

                <!-- Stock info -->
                <div class="stock-info">
                  <span class="stock-label">Stock:</span>
                  <% if (product.stock <= 0) { %>
                    <span class="stock-badge stock-badge--out">Out of Stock</span>
                  <% } else if (product.stock < 5) { %>
                    <span class="stock-badge stock-badge--low">Low Stock (<%= product.stock %> left)</span>
                  <% } else { %>
                    <span class="stock-badge stock-badge--in"><%= product.stock %> Units</span>
                  <% } %>
                </div>

                <!-- Status toggle -->
                <div class="product-status">
                  <span class="status-label">Listed</span>
                  <form action="/admin/products/toggle-status/<%= product._id %>" method="POST" class="toggle-form">
                    <label class="toggle-switch">
                      <input type="checkbox" class="toggle-input" <%= product.isListed ? 'checked' : '' %> />
                      <span class="toggle-track"></span>
                    </label>
                  </form>
                </div>

                <!-- Actions -->
                <div class="product-actions">
                  <a href="/admin/products/edit/<%= product._id %>" class="btn btn--edit">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Edit
                  </a>
                  <button type="button" class="btn btn--delete" data-id="<%= product._id %>" data-name="<%= product.name %>">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    Delete
                  </button>
                </div>
              </div>
            </article>
          <% }); %>
        </section>
      <% } else { %>
        <!-- ── Empty State ── -->
        <section class="empty-state">
          <div class="empty-illustration">
            <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="10" y="25" width="100" height="75" rx="16" fill="rgba(160,106,69,0.08)" stroke="rgba(160,106,69,0.25)" stroke-width="2"/>
              <rect x="30" y="40" width="60" height="8" rx="4" fill="rgba(160,106,69,0.13)"/>
              <rect x="30" y="54" width="40" height="8" rx="4" fill="rgba(160,106,69,0.10)"/>
              <circle cx="95" cy="25" r="18" fill="rgba(58,37,27,0.1)" stroke="rgba(58,37,27,0.2)" stroke-width="2"/>
              <line x1="90" y1="25" x2="100" y2="25" stroke="rgba(58,37,27,0.35)" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="95" y1="20" x2="95" y2="30" stroke="rgba(58,37,27,0.35)" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h2>No products found</h2>
          <p>Create a product to populate your inventory.</p>
          <a href="/admin/products/add" class="add-btn add-btn--lg">+ Create Your First Product</a>
        </section>
      <% } %>
    </main>
  </div>

  <!-- ── Delete Confirmation Modal ── -->
  <div class="modal-overlay" id="deleteModal">
    <div class="modal">
      <div class="modal__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      </div>
      <h3>Delete Product</h3>
      <p>Are you sure you want to delete <strong id="deleteName"></strong>? This action cannot be undone.</p>
      <form id="deleteForm" method="POST" action="">
        <div class="modal__actions">
          <button type="button" class="btn btn--cancel" id="cancelDelete">Cancel</button>
          <button type="submit" class="btn btn--confirm-delete">Yes, Delete</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/admin/products/list.js"></script>
</body>
</html>

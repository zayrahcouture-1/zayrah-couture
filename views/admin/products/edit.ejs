<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zayrah | Edit Product</title>
  <link rel="stylesheet" href="/css/admin/products/edit.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
</head>
<body>
  <div class="dashboard">
    <!-- ── Sidebar ── -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__brand">
        <div class="brand-mark">Z</div>
        <div>
          <h2><span class="brand-name">Zayrah</span> Dashboard</h2>
          <p>Admin panel</p>
        </div>
      </div>

      <nav class="sidebar__nav">
        <a href="/admin/dashboard" class="nav-link">Overview</a>
        <a href="/admin/products" class="nav-link active">Products</a>
        <a href="/admin/categories" class="nav-link">Categories</a>
        <a href="#" class="nav-link">Settings</a>
      </nav>
    </aside>

    <div class="overlay" id="overlay"></div>

    <!-- ── Main Content ── -->
    <main class="main">
      <header class="topbar">
        <button class="menu-btn" id="menuBtn" aria-label="Open menu">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <div class="topbar__title">
          <h1>Edit Product</h1>
          <p>Update product details and collection settings</p>
        </div>

        <div class="profile">
          <div class="avatar">AR</div>
          <div>
            <strong>Admin Rizan</strong>
            <span>Super Admin</span>
          </div>
        </div>
      </header>

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/admin/products" class="breadcrumb__link">Products</a>
        <span class="breadcrumb__sep">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
        <span class="breadcrumb__current"><%= product.name %></span>
        <span class="breadcrumb__sep">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
        <span class="breadcrumb__current">Edit</span>
      </nav>

      <!-- Form Card -->
      <section class="form-card">
        <div class="form-card__header">
          <div class="form-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </div>
          <div>
            <h2 class="form-card__title">Edit Product Details</h2>
            <p class="form-card__subtitle">Modify the fields below to update "<%= product.name %>"</p>
          </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert--error">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span><%= error %></span>
          </div>
        <% } %>

        <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data" id="productForm" novalidate>

          <!-- Hidden Input for Removed Cloudinary Image public_ids -->
          <input type="hidden" name="removedImages" id="removedImagesFlag" value="" />

          <div class="form-grid">
            <!-- Left Column: Primary Details -->
            <div class="form-column">
              <!-- Product Name -->
              <div class="field" id="nameField">
                <label class="field__label" for="productName">Product Name <span class="required">*</span></label>
                <div class="field__wrap">
                  <span class="field__icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                  </span>
                  <input type="text" class="field__input" id="productName" name="name" value="<%= product.name %>" placeholder="e.g. Silk Organza Anarkali" required autocomplete="off" />
                </div>
                <span class="field__error-msg" id="nameError">Product name is required</span>
              </div>

              <!-- Category Dropdown -->
              <div class="field" id="categoryField">
                <label class="field__label" for="productCategory">Category <span class="required">*</span></label>
                <div class="field__wrap">
                  <span class="field__icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
                  </span>
                  <select class="field__input" id="productCategory" name="category" required>
                    <option value="" disabled>Select category…</option>
                    <% if (categories && categories.length > 0) { %>
                      <% categories.forEach(function(cat) { %>
                        <option value="<%= cat._id %>" <%= (product.category && product.category._id.toString() === cat._id.toString()) ? 'selected' : '' %>><%= cat.name %></option>
                      <% }); %>
                    <% } %>
                  </select>
                </div>
                <span class="field__error-msg" id="categoryError">Please select a category</span>
              </div>

              <!-- Description -->
              <div class="field">
                <label class="field__label" for="productDesc">Description</label>
                <div class="field__wrap field__wrap--textarea">
                  <span class="field__icon field__icon--textarea">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
                  </span>
                  <textarea class="field__textarea" id="productDesc" name="description" placeholder="Enter product descriptions, materials used, size options…" rows="5" maxlength="1000"><%= product.description %></textarea>
                </div>
                <div class="char-count"><span id="charCurrent"><%= product.description.length %></span> / 1000 characters</div>
              </div>
            </div>

            <!-- Right Column: Numbers & Stock -->
            <div class="form-column">
              <!-- Pricing Row -->
              <div class="fields-row">
                <!-- Original Price -->
                <div class="field" id="priceField">
                  <label class="field__label" for="productPrice">Price (₹) <span class="required">*</span></label>
                  <div class="field__wrap">
                    <span class="field__icon">
                      <strong>₹</strong>
                    </span>
                    <input type="number" class="field__input" id="productPrice" name="price" value="<%= product.price %>" placeholder="9999" min="0" required autocomplete="off" />
                  </div>
                  <span class="field__error-msg" id="priceError">Valid price is required</span>
                </div>

                <!-- Discount Price -->
                <div class="field" id="discountField">
                  <label class="field__label" for="productDiscount">Discount Price (₹)</label>
                  <div class="field__wrap">
                    <span class="field__icon">
                      <strong>₹</strong>
                    </span>
                    <input type="number" class="field__input" id="productDiscount" name="discountPrice" value="<%= product.discountPrice || '' %>" placeholder="e.g. 7999" min="0" autocomplete="off" />
                  </div>
                  <span class="field__error-msg" id="discountError">Discount price must be less than original price</span>
                </div>
              </div>

              <!-- Stock Quantity -->
              <div class="field" id="stockField">
                <label class="field__label" for="productStock">Available Stock <span class="required">*</span></label>
                <div class="field__wrap">
                  <span class="field__icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                  </span>
                  <input type="number" class="field__input" id="productStock" name="stock" value="<%= product.stock %>" placeholder="e.g. 15" min="0" required autocomplete="off" />
                </div>
                <span class="field__error-msg" id="stockError">Valid stock quantity is required</span>
              </div>

              <!-- Product Images -->
              <div class="field">
                <label class="field__label">Manage Images <span class="muted">(Min 1, Max 5 total)</span></label>
                
                <!-- Existing Images Grid -->
                <div class="existing-images-label">Existing Images:</div>
                <div class="existing-grid" id="existingGrid">
                  <% if (product.images && product.images.length > 0) { %>
                    <% product.images.forEach(function(img) { %>
                      <div class="existing-item" data-id="<%= img.public_id %>">
                        <img src="<%= img.url %>" alt="Product image" />
                        <button type="button" class="existing-item__remove" title="Remove image">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                      </div>
                    <% }); %>
                  <% } else { %>
                    <p class="no-existing-text">No images currently uploaded.</p>
                  <% } %>
                </div>

                <!-- New Upload Zone -->
                <div class="upload-zone" id="uploadZone">
                  <input type="file" name="images" id="imageInput" accept="image/*" multiple hidden />
                  <div class="upload-zone__content" id="uploadContent">
                    <div class="upload-zone__icon">
                      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    </div>
                    <p class="upload-zone__text">Upload additional images, or <span class="upload-zone__link">browse</span></p>
                    <p class="upload-zone__hint">Supports JPG, PNG, WebP · Max 5MB per file</p>
                  </div>
                  
                  <!-- Preview Grid -->
                  <div class="upload-grid" id="uploadGrid" style="display: none;"></div>
                </div>
                <span class="field__error-msg" id="imagesError" style="display:none; margin-top: 8px;">At least one product image is required</span>
              </div>
            </div>
          </div>

          <!-- Toggle Switches -->
          <div class="toggles-row">
            <div class="toggle-group">
              <label class="toggle-group__label" for="isFeatured">
                <div>
                  <span class="toggle-group__title">Featured Product</span>
                  <span class="toggle-group__desc">Showcase this item on the main store page</span>
                </div>
              </label>
              <label class="toggle-switch">
                <input type="checkbox" name="isFeatured" id="isFeatured" <%= product.isFeatured ? 'checked' : '' %> />
                <span class="toggle-switch__slider"></span>
              </label>
            </div>

            <div class="toggle-group">
              <label class="toggle-group__label" for="isListed">
                <div>
                  <span class="toggle-group__title">Listed</span>
                  <span class="toggle-group__desc">Make this product visible to customers</span>
                </div>
              </label>
              <label class="toggle-switch">
                <input type="checkbox" name="isListed" id="isListed" <%= product.isListed ? 'checked' : '' %> />
                <span class="toggle-switch__slider"></span>
              </label>
            </div>
          </div>

          <!-- Form Actions -->
          <div class="form-actions">
            <a href="/admin/products" class="btn btn--secondary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
              Cancel
            </a>
            <button type="submit" class="btn btn--primary" id="submitBtn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="btn__text">Update Product</span>
            </button>
          </div>

        </form>
      </section>
    </main>
  </div>

  <!-- Image Crop Modal -->
  <div class="modal-overlay" id="cropModalOverlay">
    <div class="modal modal--crop">
      <h3>Crop Image</h3>
      <p style="margin-bottom: 16px; color: var(--muted); font-size: .92rem;">Adjust the selection to crop this product image (1:1 aspect ratio).</p>
      <div class="cropper-container">
        <img id="cropperImage" src="" alt="Source image to crop" />
      </div>
      <div class="modal__actions">
        <button type="button" class="btn btn--cancel" id="cancelCrop">Cancel</button>
        <button type="button" class="btn btn--confirm-crop" id="confirmCrop">
          <span class="btn__text">Crop &amp; Apply</span>
        </button>
      </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
  <script src="/js/admin/products/edit.js"></script>
</body>
</html>

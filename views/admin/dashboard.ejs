<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zayrah | Admin Dashboard</title>
  <link rel="stylesheet" href="/css/admin/dashboard.css" />
</head>
<body>
  <div class="dashboard">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__brand">
        <div class="brand-mark">Z</div>
        <div>
          <h2><span class="brand-name">Zayrah</span> Dashboard</h2>
          <p>Admin panel</p>
        </div>
      </div>

      <nav class="sidebar__nav">
        <a href="/admin/dashboard" class="nav-link active">Overview</a>
        <a href="/admin/products" class="nav-link">Product Management</a>
        <a href="/admin/categories" class="nav-link">Category Management</a>
        <a href="#" class="nav-link">Settings</a>
        <a href="/admin/logout" class="nav-link" style="color: var(--red); border: 1px solid rgba(138, 47, 47, 0.2); background: rgba(138, 47, 47, 0.04); margin-top: 20px; font-weight: 600;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" style="margin-right: 8px; vertical-align: middle;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Logout
        </a>
      </nav>
    </aside>

    <div class="overlay" id="overlay"></div>

    <main class="main">
      <header class="topbar">
        <button class="menu-btn" id="menuBtn" aria-label="Open menu">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <div class="topbar__title">
          <h1><span class="brand-name">Zayrah</span> Dashboard</h1>
          <p>Welcome back, Director. Here is your daily curated summary.</p>
        </div>


      </header>

      <section class="stats">
        <article class="stat-card">
          <span class="stat-label">Total Products</span>
          <div class="stat-value"><%= typeof totalProducts !== 'undefined' ? totalProducts : 0 %></div>
          <p>Inventory across all collections</p>
        </article>

        <article class="stat-card">
          <span class="stat-label">Total Categories</span>
          <div class="stat-value"><%= typeof totalCategories !== 'undefined' ? totalCategories : 0 %></div>
          <p>Active storefront groups</p>
        </article>
      </section>




    </main>
  </div>

  <script src="/js/admin/dashboard.js"></script>
  <%- include('partials/loader') %>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zayrah | Admin Dashboard</title>
  <link rel="stylesheet" href="/css/admin/dashboard.css" />
</head>
<body>
  <div class="dashboard">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__brand">
        <div class="brand-mark">Z</div>
        <div>
          <h2><span class="brand-name">Zayrah</span> Dashboard</h2>
          <p>Admin panel</p>
        </div>
      </div>

      <nav class="sidebar__nav">
        <a href="/admin/dashboard" class="nav-link active">Overview</a>
        <a href="/admin/products" class="nav-link">Products</a>
        <a href="/admin/categories" class="nav-link">Categories</a>
        <a href="#" class="nav-link">Settings</a>
      </nav>
    </aside>

    <div class="overlay" id="overlay"></div>

    <main class="main">
      <header class="topbar">
        <button class="menu-btn" id="menuBtn" aria-label="Open menu">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <div class="topbar__title">
          <h1><span class="brand-name">Zayrah</span> Dashboard</h1>
          <p>Welcome back, Director. Here is your daily curated summary.</p>
        </div>

        <div class="profile">
          <div class="avatar">AR</div>
          <div>
            <strong>Admin Rizan</strong>
            <span>Super Admin</span>
          </div>
        </div>
      </header>

      <section class="stats">
        <article class="stat-card">
          <span class="stat-label">Total Products</span>
          <div class="stat-value"><%= totalProducts || 1240 %></div>
          <p>Inventory across all collections</p>
        </article>

        <article class="stat-card">
          <span class="stat-label">Total Categories</span>
          <div class="stat-value"><%= totalCategories || 18 %></div>
          <p>Active storefront groups</p>
        </article>
      </section>

      <section class="spotlight-head">
        <div>
          <h2>Inventory Spotlight</h2>
          <p>Highest performing pieces this quarter.</p>
        </div>
      </section>

      <section class="spotlight-grid">
        <article class="spot-card">
          <div class="spot-img spot-1">
            <span class="badge">Best Seller</span>
          </div>
          <h3>The Obsidian Drape</h3>
          <p>Elegant couture silhouette</p>
        </article>

        <article class="spot-card">
          <div class="spot-img spot-2">
            <span class="badge badge-red">New Drop</span>
          </div>
          <h3>Floral Atelier Veil</h3>
          <p>Bridal premium selection</p>
        </article>

        <article class="spot-card">
          <div class="spot-img spot-3">
            <span class="badge">Top Rated</span>
          </div>
          <h3>Structured Heritage Blazer</h3>
          <p>Tailored formal wear</p>
        </article>

        <article class="spot-card">
          <div class="spot-img spot-4">
            <span class="badge">Available</span>
          </div>
          <h3>Marbled Clutch</h3>
          <p>Minimal accessories</p>
        </article>
      </section>

      <div class="actions">
        <button class="collection-btn">+ New Collection</button>
      </div>
    </main>
  </div>

  <script src="/js/admin/dashboard.js"></script>
</body>
</html>
<!-- ── Loading Overlay ── -->
<div class="loading-overlay loading-initially" id="loadingOverlay">
  <div class="loading-spinner-container">
    <div class="loading-spinner"></div>
    <div class="loading-text">Loading, please wait...</div>
  </div>
</div>

<style>
/* ---- Loading Overlay Styles ---- */
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(35, 27, 23, 0.45);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 99999;
  display: none;
  place-items: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}
.loading-overlay.show,
.loading-overlay.loading-initially {
  display: grid;
  opacity: 1;
}
.loading-spinner-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.loading-spinner {
  width: 48px;
  height: 48px;
  border: 4px solid rgba(255, 255, 255, 0.25);
  border-top-color: #a06a45; /* warm accent color matching Zayrah Couture */
  border-radius: 50%;
  animation: spinLoader 1s linear infinite;
}
.loading-text {
  color: #ffffff;
  font-family: inherit;
  font-size: 0.95rem;
  font-weight: 500;
  letter-spacing: 0.5px;
  text-shadow: 0 2px 4px rgba(35, 27, 23, 0.3);
}
@keyframes spinLoader {
  to { transform: rotate(360deg); }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const loader = document.getElementById('loadingOverlay');
  if (!loader) return;

  // Function to hide the loader overlay
  const hideLoader = () => {
    loader.classList.remove('show');
    loader.classList.remove('loading-initially');
  };

  // Hide immediately as DOM is ready
  hideLoader();

  // Also bind to window load event as double safety
  window.addEventListener('load', hideLoader);

  // Handle browser back/forward cache navigation
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      hideLoader();
    }
  });

  // 1. Listen to all forms on the page
  document.querySelectorAll('form').forEach(form => {
    form.addEventListener('submit', (e) => {
      // Check HTML5 validity first
      if (form.checkValidity && !form.checkValidity()) {
        return;
      }
      
      // Defer overlay activation to next event loop tick to allow client-side validation scripts
      // to run and potentially call e.preventDefault() first
      setTimeout(() => {
        if (!e.defaultPrevented) {
          loader.classList.add('show');
        }
      }, 0);
    });
  });

  // 2. Listen to all same-origin anchor link clicks for page navigation loader
  document.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href');
      
      // Skip if no href, JavaScript trigger, anchor hash, mailto, or tel links
      if (!href || href.startsWith('javascript:') || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) {
        return;
      }
      
      // Skip target="_blank"
      if (link.getAttribute('target') === '_blank') {
        return;
      }

      // Skip download links
      if (link.hasAttribute('download')) {
        return;
      }

      // Check if it is same origin
      try {
        const url = new URL(link.href, window.location.href);
        if (url.origin !== window.location.origin) {
          return;
        }
      } catch (err) {
        return;
      }

      // Defer showing loader slightly so other click handlers can execute first
      setTimeout(() => {
        if (!e.defaultPrevented) {
          loader.classList.add('show');
        }
      }, 50);
    });
  });

  // 3. Confirm logout on admin logout links
  document.querySelectorAll('a[href="/admin/logout"]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const href = link.getAttribute('href');
      
      const showConfirm = () => {
        Swal.fire({
          title: 'Confirm Logout',
          text: 'Are you sure you really want to logout?',
          icon: 'question',
          showCancelButton: true,
          confirmButtonColor: '#8a2f2f',
          cancelButtonColor: '#7a8a7a',
          confirmButtonText: 'Yes, Logout',
          cancelButtonText: 'Cancel',
          background: '#fcfcfc',
          color: '#2f4f3e'
        }).then((result) => {
          if (result.isConfirmed) {
            loader.classList.add('show');
            window.location.href = href;
          }
        });
      };

      if (typeof Swal === 'undefined') {
        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/sweetalert2@11';
        script.onload = showConfirm;
        document.head.appendChild(script);
      } else {
        showConfirm();
      }
    });
  });
});
</script>

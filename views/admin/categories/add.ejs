<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zayrah | Add Category</title>
  <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico?v=1" />
  <link rel="stylesheet" href="/css/admin/categories/add.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
</head>
<body>
  <div class="dashboard">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__brand">
        <div class="brand-mark">Z</div>
        <div>
          <h2><span class="brand-name">Zayrah</span> Dashboard</h2>
          <p>Admin panel</p>
        </div>
      </div>

      <nav class="sidebar__nav">
        <a href="/admin/dashboard" class="nav-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          Overview
        </a>
        <a href="/admin/products" class="nav-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          Product Management
        </a>
        <a href="/admin/categories" class="nav-link active">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
          Category Management
        </a>
        <a href="/admin/settings" class="nav-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
          Settings
        </a>
        <a href="/admin/logout" class="nav-link" style="color: var(--red); border: 1px solid rgba(138, 47, 47, 0.2); background: rgba(138, 47, 47, 0.04); margin-top: 20px; font-weight: 600;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" style="margin-right: 8px; vertical-align: middle;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Logout
        </a>
      </nav>
    </aside>

    <div class="overlay" id="overlay"></div>

    <main class="main">
      <header class="topbar">
        <button class="menu-btn" id="menuBtn" aria-label="Open menu">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <div class="topbar__title">
          <h1>Add Category</h1>
          <p>Create a new product category</p>
        </div>


      </header>

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/admin/categories" class="breadcrumb__link">Categories</a>
        <span class="breadcrumb__sep">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
        <span class="breadcrumb__current">Add New</span>
      </nav>

      <!-- Form Card -->
      <section class="form-card">
        <div class="form-card__header">
          <div class="form-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg>
          </div>
          <div>
            <h2 class="form-card__title">Category Details</h2>
            <p class="form-card__subtitle">Fill in the information below to create a new category</p>
          </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert--error">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span><%= error %></span>
          </div>
        <% } %>

        <form action="/admin/categories/add" method="POST" enctype="multipart/form-data" id="categoryForm" novalidate>

          <!-- Category Name -->
          <div class="field" id="nameField">
            <label class="field__label" for="categoryName">Category Name <span class="required">*</span></label>
            <div class="field__wrap">
              <span class="field__icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              </span>
              <input type="text" class="field__input" id="categoryName" name="name" placeholder="e.g. Evening Couture" required autocomplete="off" />
            </div>
            <span class="field__error-msg" id="nameError">Category name is required</span>
          </div>

          <!-- Description -->
          <div class="field">
            <label class="field__label" for="categoryDesc">Description</label>
            <div class="field__wrap field__wrap--textarea">
              <span class="field__icon field__icon--textarea">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
              </span>
              <textarea class="field__textarea" id="categoryDesc" name="description" placeholder="Describe this category…" rows="4" maxlength="500"></textarea>
            </div>
            <div class="char-count"><span id="charCurrent">0</span> / 500 characters</div>
          </div>

          <!-- Image Upload -->
          <div class="field" id="imageField">
            <label class="field__label">Category Image <span class="required">*</span></label>
            <div class="upload-zone" id="uploadZone">
              <input type="file" name="image" id="imageInput" accept="image/*" hidden />
              <div class="upload-zone__content" id="uploadContent">
                <div class="upload-zone__icon">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
                <p class="upload-zone__text">Drag &amp; drop an image here, or <span class="upload-zone__link">browse</span></p>
                <p class="upload-zone__hint">Supports JPG, PNG, WebP · Max 5MB</p>
              </div>
              <div class="upload-zone__preview" id="uploadPreview" style="display:none;">
                <img id="previewImg" src="" alt="Category preview" />
                <button type="button" class="upload-zone__remove" id="removeImage" title="Remove image">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
              </div>
            </div>
            <span class="field__error-msg" id="imageError">Category image is required</span>
          </div>

          <!-- Category Variants -->
          <div class="field" id="variantsField" style="margin-bottom: 30px;">
            <label class="field__label" style="font-weight: 600;">Category Variants <span class="required">*</span></label>
            <p style="font-size: 0.85rem; color: var(--muted); margin-bottom: 12px; margin-top: 4px;">Define variants for this category. Products added under this category will inherit these variants, and users will select from these options. (At least one variant is required)</p>
            
            <div id="variantsContainer" style="display: flex; flex-direction: column; gap: 14px;">
              <!-- Dynamic variant rows will go here -->
            </div>
            
            <button type="button" id="addVariantBtn" class="btn btn--secondary" style="margin-top: 14px; display: inline-flex; align-items: center; gap: 6px; padding: 10px 18px; font-size: 0.9rem; width: auto; border: 1.5px dashed var(--line); border-radius: 12px; background: transparent; cursor: pointer; color: var(--text);">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add Custom Variant
            </button>
            <span class="field__error-msg" id="variantsError" style="margin-top: 8px;">At least one variant with name and options is required</span>
          </div>

          <!-- Toggle Switches -->
          <!-- <div class="toggles-row">
            <div class="toggle-group">
              <label class="toggle-group__label" for="isFeatured">
                <div>
                  <span class="toggle-group__title">Featured Category</span>
                  <span class="toggle-group__desc">Display this category in the featured section</span>
                </div>
              </label>
              <label class="toggle-switch">
                <input type="checkbox" name="isFeatured" id="isFeatured" />
                <span class="toggle-switch__slider"></span>
              </label>
            </div> -->

            <!-- <div class="toggle-group">
              <label class="toggle-group__label" for="isListed">
                <div>
                  <span class="toggle-group__title">Listed</span>
                  <span class="toggle-group__desc">Make this category visible on the storefront</span>
                </div>
              </label>
              <label class="toggle-switch">
                <input type="checkbox" name="isListed" id="isListed" checked />
                <span class="toggle-switch__slider"></span>
              </label>
            </div>
          </div> -->

          <!-- Form Actions -->
          <div class="form-actions">
            <a href="/admin/categories" class="btn btn--secondary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
              Cancel
            </a>
            <button type="submit" class="btn btn--primary" id="submitBtn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
              <span class="btn__text">Save Category</span>
            </button>
          </div>

        </form>
      </section>
    </main>
  </div>

  <!-- Image Crop Modal -->
  <div class="modal-overlay" id="cropModalOverlay">
    <div class="modal modal--crop">
      <h3>Crop Image</h3>
      <p style="margin-bottom: 16px; color: var(--muted); font-size: .92rem;">Adjust the selection to crop your category image (3:4 aspect ratio).</p>
      <div class="cropper-container">
        <img id="cropperImage" src="" alt="Source image to crop" />
      </div>
      <div class="modal__actions">
        <button type="button" class="btn btn--cancel" id="cancelCrop">Cancel</button>
        <button type="button" class="btn btn--confirm-crop" id="confirmCrop">
          <span class="btn__text">Crop &amp; Apply</span>
        </button>
      </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
  <script src="/js/admin/categories/add.js"></script>
  <%- include('../partials/loader') %>
</body>
</html>
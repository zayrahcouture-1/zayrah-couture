<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zayrah | Categories</title>
  <link rel="stylesheet" href="/css/admin/categories/list.css" />
</head>
<body>

  <!-- ── Flash Toasts ── -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="toast toast--success" id="toast"><%= success %></div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="toast toast--error" id="toast"><%= error %></div>
  <% } %>

  <div class="dashboard">
    <!-- ── Sidebar (identical to dashboard) ── -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__brand">
        <div class="brand-mark">Z</div>
        <div>
          <h2><span class="brand-name">Zayrah</span> Dashboard</h2>
          <p>Admin panel</p>
        </div>
      </div>

      <nav class="sidebar__nav">
        <a href="/admin/dashboard" class="nav-link">Overview</a>
        <a href="/admin/products" class="nav-link">Product Management</a>
        <a href="/admin/categories" class="nav-link active">Category Management</a>
        <a href="#" class="nav-link">Settings</a>
      </nav>
    </aside>

    <!-- ── Mobile overlay ── -->
    <div class="overlay" id="overlay"></div>

    <!-- ── Main content ── -->
    <main class="main">
      <!-- Topbar (identical to dashboard) -->
      <header class="topbar">
        <button class="menu-btn" id="menuBtn" aria-label="Open menu">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <div class="topbar__title">
          <h1>Category Management</h1>
          <p>Manage your product categories</p>
        </div>

        <div class="profile">
          <div class="avatar">AR</div>
          <div>
            <strong>Admin Rizan</strong>
            <span>Super Admin</span>
          </div>
        </div>
      </header>

      <!-- ── Toolbar ── -->
      <section class="toolbar">
        <div class="search-box">
          <input type="text" id="searchInput" class="search-input" placeholder="Search categories…" autocomplete="off" />
          <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <a href="/admin/categories/add" class="add-btn">+ Add Category</a>
      </section>

      <% if (categories && categories.length > 0) { %>
        <!-- ── Category Grid ── -->
        <section class="categories-grid" id="categoriesGrid">
          <% categories.forEach(function(category, index) { %>
            <article class="category-card" data-name="<%= category.name.toLowerCase() %>" style="animation-delay: <%= index * 0.06 %>s">
              <!-- Thumbnail -->
              <div class="category-thumb">
                <% if (category.image && category.image.url) { %>
                  <img src="<%= category.image.url %>" alt="<%= category.name %>" />
                <% } else { %>
                  <div class="thumb-placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                  </div>
                <% } %>
                <% if (category.isFeatured) { %>
                  <span class="badge--featured">★ Featured</span>
                <% } %>
              </div>

              <!-- Info -->
              <div class="category-body">
                <h3 class="category-name"><%= category.name %></h3>
                <span class="category-slug">/<%= category.slug %></span>

                <% if (category.description) { %>
                  <p class="category-desc"><%= category.description.length > 80 ? category.description.substring(0, 80) + '…' : category.description %></p>
                <% } %>

                <!-- Status toggle -->
                <div class="category-status">
                  <span class="status-label">Listed</span>
                  <form action="/admin/categories/toggle-status/<%= category._id %>" method="POST" class="toggle-form">
                    <label class="toggle-switch">
                      <input type="checkbox" class="toggle-input" <%= category.isListed ? 'checked' : '' %> />
                      <span class="toggle-track"></span>
                    </label>
                  </form>
                </div>

                <!-- Meta row -->
                <div class="category-meta">
                  <span class="meta-date">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <%= new Date(category.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  </span>
                </div>

                <!-- Actions -->
                <div class="category-actions">
                  <a href="/admin/categories/edit/<%= category._id %>" class="btn btn--edit">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Edit
                  </a>
                  <button type="button" class="btn btn--delete" data-id="<%= category._id %>" data-name="<%= category.name %>">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    Delete
                  </button>
                </div>
              </div>
            </article>
          <% }); %>
        </section>
      <% } else { %>
        <!-- ── Empty State ── -->
        <section class="empty-state">
          <div class="empty-illustration">
            <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="10" y="25" width="100" height="75" rx="16" fill="rgba(160,106,69,0.08)" stroke="rgba(160,106,69,0.25)" stroke-width="2"/>
              <rect x="22" y="40" width="76" height="10" rx="5" fill="rgba(160,106,69,0.13)"/>
              <rect x="22" y="56" width="50" height="10" rx="5" fill="rgba(160,106,69,0.10)"/>
              <rect x="22" y="72" width="62" height="10" rx="5" fill="rgba(160,106,69,0.08)"/>
              <circle cx="95" cy="25" r="18" fill="rgba(58,37,27,0.1)" stroke="rgba(58,37,27,0.2)" stroke-width="2"/>
              <line x1="90" y1="25" x2="100" y2="25" stroke="rgba(58,37,27,0.35)" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="95" y1="20" x2="95" y2="30" stroke="rgba(58,37,27,0.35)" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h2>No categories yet</h2>
          <p>Start organizing your products by creating your first category.</p>
          <a href="/admin/categories/add" class="add-btn add-btn--lg">+ Create Your First Category</a>
        </section>
      <% } %>
    </main>
  </div>

  <!-- ── Delete Confirmation Modal ── -->
  <div class="modal-overlay" id="deleteModal">
    <div class="modal">
      <div class="modal__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      </div>
      <h3>Delete Category</h3>
      <p>Are you sure you want to delete <strong id="deleteName"></strong>? This action cannot be undone.</p>
      <form id="deleteForm" method="POST" action="">
        <div class="modal__actions">
          <button type="button" class="btn btn--cancel" id="cancelDelete">Cancel</button>
          <button type="submit" class="btn btn--confirm-delete">Yes, Delete</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/admin/categories/list.js"></script>
  <%- include('../partials/loader') %>
</body>
</html>